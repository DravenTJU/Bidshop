{
  "name": "bidshop-tests",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "test":        "bddgen && playwright test --project=api --project=ui",
    "test:api":    "playwright test --project=api",
    "test:ui":     "bddgen && playwright test --project=ui",
    "test:mobile": "bddgen && playwright test --project=ui-mobile",
    "report":      "playwright show-report playwright-report",
    "report:api":  "playwright show-report playwright-report/api",
    "report:ui":   "playwright show-report playwright-report/ui",
    "report:mobile": "playwright show-report playwright-report/ui-mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "dotenv": "^16.4.0",
    "playwright-bdd": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
